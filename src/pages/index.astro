                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="swiper-pagination"></div>
                    </div>
                    <!--SLIDER PARA MOVIL -->
                    <div class="swiper mySwiperMobile">
                        <div class="swiper-wrapper">
                            <div class="swiper-slide">
                                <div class="wrapper-slider-image">
                                    <Image
                                        src={carousel1}
                                        alt="Imagen escabadora retirando tierra para la colocación de los cimientos"
                                    />
                                    <div class="wrapper-slider-image_home">
                                        <a href="" class="btn-slider-image btn"
                                            >Ver más</a
