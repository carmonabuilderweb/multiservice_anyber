                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="wrapper-slider-image">
                                    <img
                                        src="https://picsum.photos/seed/proj4/600/800"
                                        alt=""
                                    />
                                    <div>
                                        <a href="" class="btn-slider-image btn"
                                            >Ver más</a
                                        >
                                        <p>Colocación de ventanas</p>
