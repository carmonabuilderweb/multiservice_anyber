---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logoHero from "../assets/images/logo_mejor_calidad.png";
import poolService from "../assets/images/index/piscina.jpeg";
import wcService from "../assets/images/index/baño.jpeg";
import logoGoogle from "../assets/images/logoGoogleSVG.svg";
import expertReform from "../assets/images/index/expert-reform.jpg";
import carousel1 from "../assets/images/index/corrusel/movimientos01.jpeg";
import videoHouse from '../assets/video/video_house.mp4';
---

<Layout>
    <main>
        <!-- Hero Section -->
        <section id="inicio" class="hero">
            <div class="video-container">
                <video
                    id="hero-video"
                    preload="auto"
                    muted
                    autoplay
                    playsinline
                >
                    <source src="../assets/video/video_house.mp4" type="video/mp4" />
                    <source
                        src={videoHouse}
                        type="video/mp4"
                    />
                </video>

                <div class="image_logo_hero">
                    <Image src={logoHero} alt="Multiservicios ANYBER Logo" />

                    <div class="hero-overlay"></div>
                </div>
                <div class="hero-content">
                    <h1 class="hero-title" data-i18n="hero_title">
                        Especialistas en reformas integrales, cocinas y baños
                        desde hace +25 años
                    </h1>
                    <a
                        href="#contacto"
                        class="btn btn-primary"
                        data-i18n="hero_btn">Resolvemos tus dudas</a
                    >
                    <div class="scroll-indicator">
                        <p data-i18n="scroll_text">Scroll para experimentar</p>
                        <div class="arrow-down"></div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Sobre Nosotros -->
        <section id="empresa" class="about section-padding">
            <div class="container">
                <h2 class="section-subtitle efecto-sombra" data-i18n="about_welcome">Bienvenidos a Multiservicios AnyBer</h3>

                <div class="about-grid">
                    <div class="about-images">
                        <div class="img-wrapper img-1">
                            <Image src={poolService} alt="Imagen de una piscina recien reformada.">
                        </div>
                        <div class="img-wrapper img-2">
                            <Image src={wcService} alt="Imagen de un cuarto de baño recien reformado.">
                        </div>
                    </div>
                    <div class="about-text">
                        <h4 data-i18n="about_heading">SOBRE NOSOTROS</h4>
                        <p data-i18n="about_p1">En Multiservicios AnyBer, transformamos espacios en hogares. Con más de
                            25 años de experiencia en el sector de las reformas integrales, nos hemos consolidado como
                            referentes en calidad, compromiso y diseño innovador.</p>
                        <p data-i18n="about_p2">Nuestro equipo de profesionales altamente cualificados se encarga de
                            cada detalle, desde la planificación inicial hasta la entrega final, garantizando resultados
                            que superan las expectativas de nuestros clientes.</p>
                        <a href="./company.html" class="btn btn-outline" data-i18n="read_more">LEER MÁS</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Nuestro Servicios -->
        <section id="servicios" class="services section-padding">
                <div class="container">
                    <h2
                        class="section-subtitle text-center efecto-sombra"
                        data-i18n="services_title"
                    >
                        Nuestros Servicios
                    </h2>

                    <div class="services-grid">
                        <div class="service-card flip-card"  data-aos="fade-left" >
                            <div class="service-inner flip-card-inner">
                                <div class="service-front flip-card-front">
                                    <img
                                        src="./images/card/integral_reforma_card.jpg"
                                        alt="Imagen de una vivienda en obras."
                                    />
                                    <h3 data-i18n="service_1">
                                        Reformas integrales
                                    </h3>
                                </div>
                                <div class="service-back">
                                    <p data-i18n="service_1_desc">
                                        Transformación completa de viviendas y
                                        locales comerciales con acabados de
                                        lujo.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="service-card flip-card" data-aos="fade-up">
                            <div class="service-inner flip-card-inner">
                                <div class="service-front flip-card-front">
                                    <img

                                        src="./images/card/working_ingenier_card.jpg"
                                        alt="Imagen de una arquitecta revisando los planos"
                                    />
                                    <h3 data-i18n="service_2">
                                        Dirección y ejecución de obras
                                    </h3>
                                </div>
                                <div class="service-back flip-card-back">
                                    <p data-i18n="service_2_desc">
                                        Gestión profesional de proyectos,
                                        permisos y coordinación de gremios.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="service-card flip-card" data-aos="fade-ritgh">
                            <div class="service-inner flip-card-inner">
                                <div class="service-front">
                                    <img

                                        src="./images/card/wc_card.jpg"
                                        alt="Imagen de la reforma de un baño ya finalizado y decorado."
                                    />
                                    <h3 data-i18n="service_3">
                                        Reformas de baños y cocinas
                                    </h3>
                                </div>
                                <div class="service-back">
                                    <p data-i18n="service_3_desc">
                                        Especialistas en los espacios más
                                        importantes de tu hogar. Diseño y
                                        funcionalidad.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="service-card flip-card" data-aos="fade-down">
                            <div class="service-inner flip-card-inner">
                                <div class="service-front">
                                    <img
                                        src="./images/card/jardineria_card.jpg"
                                        alt="Imagen de un jardin"
                                    />
                                    <h3 data-i18n="service_4">Jardinería</h3>
                                </div>
                                <div class="service-back">
                                    <p data-i18n="service_4_desc">
                                        Diseño y mantenimiento de espacios
                                        exteriores, terrazas y jardines.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="service-card flip-card" data-aos="fade-left">
                            <div class="service-inner flip-card-inner">
                                <div class="service-front">
                                    <img
                                        src="https://picsum.photos/seed/plumbing/400/500"
                                        alt="Fontanería"
                                    />
                                    <h3 data-i18n="service_5">Fontanería</h3>
                                </div>
                                <div class="service-back">
                                    <p data-i18n="service_5_desc">
                                        Instalaciones completas, reparaciones y
                                        climatización eficiente.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-50">
                        <a
                            href="./services"
                            class="btn btn-primary"
                            data-i18n="all_services">Ver todos los servicios</a
                        >
                    </div>
                </div>
        </section>

            <!-- Proyectos -->
        <section id="proyectos" class="projects section-padding">
                <div class="container">
                    <h2
                        class="section-subtitle text-center efecto-sombra"
                        data-i18n="projects_title"
                    >
                        Nuestros Proyectos
                    </h2>

