                    <!-- SLIDER PARA PC -->
                    <div class="swiper mySwiperDesktop">
                        <div class="swiper-wrapper">
                            <div class="swiper-slide">
                                <div class="wrapper-slider-image">
                                    <Image src={carousel1} alt="" />
                                    <div>
                                        <a href="" class="btn-slider-image btn"
                                            >Ver más</a
                                        >
                                        <p>
                                            MOVIMIENTOS DE TIERRA Y EXCAVACIONES
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="wrapper-slider-image">
                                    <img
                                        src="https://picsum.photos/seed/proj1/600/800"
                                        alt=""
                                    />
                                    <div>
                                        <a href="" class="btn-slider-image btn"
                                            >Ver más</a
