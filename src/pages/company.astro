---
import Hero from "../components/Hero.astro"
import Layout  from "../layouts/Layout.astro"
---
<Layout >
        <Hero image="./images/hero_about.jpg"/>
        <section class="servicios">
            <div class="container " >
            <h2 class="section-title-bg" data-text="SOBRE NOSOTROS">SOBRE NOSOTROS</h2>
            <!-- HERO ABOUT -->
            <div class="aboutPro__hero">
                <div class="aboutPro__heroText">
                    
                    <h2 class="section-subtitle text-center efecto-sombra title-section" >SOBRE NOSOTROS</h2>
                    <p class="about_p1">
                        En <strong>Multiservicios AnyBer</strong> llevamos más de 25 años transformando viviendas en
                        hogares reales.
                        Nos especializamos en reformas integrales, diseño de interiores y soluciones personalizadas.
                    </p>
                    <p class="about_p1">
                        No solo reformamos espacios: creamos lugares donde vivir mejor.
                    </p>
                </div>

                <div class="aboutPro__stats">
                    <div class="aboutPro__stat">
                        <span>25+</span>
                        <p>Años de experiencia</p>
                    </div>

                    <div class="aboutPro__stat">
                        <span>500+</span>
                        <p>Proyectos realizados</p>
                    </div>

                    <div class="aboutPro__stat">
                        <span>100%</span>
                        <p>Clientes satisfechos</p>
                    </div>
                </div>
            </div>

            <!-- VALORES -->
            <div class="aboutPro__values">
                <h3 class="aboutPro_subtitle">NUESTOS VALORES</h3>

                <div class="aboutPro__grid">
                    <div class="aboutPro__card">
                        <h4>Calidad</h4>
                        <p>Materiales de primera y acabados cuidados al detalle.</p>
                    </div>

                    <div class="aboutPro__card">
                        <h4>Compromiso</h4>
                        <p>Cumplimos plazos y mantenemos comunicación constante.</p>
                    </div>

                    <div class="aboutPro__card">
                        <h4>Confianza</h4>
                        <p>Transparencia total en cada fase del proyecto.</p>
                    </div>

                    <div class="aboutPro__card">
                        <h4>Diseño</h4>
                        <p>Soluciones modernas adaptadas a cada cliente.</p>
                    </div>
                </div>
            </div>

            <!-- PROCESO -->
            <div class="aboutPro__process">
                <h3 class="aboutPro_subtitle">CÓMO TRABAJAMOS</h3>

                <div class="aboutPro__steps">

                    <div class="aboutPro__step">
                        <span>1</span>
                        <h4>Escuchamos tu idea</h4>
                        <p>Analizamos tu proyecto y necesidades.</p>
                    </div>

                    <div class="aboutPro__step">
                        <span>2</span>
                        <h4>Diseñamos la solución</h4>
                        <p>Planificamos cada detalle del proyecto.</p>
                    </div>

                    <div class="aboutPro__step">
                        <span>3</span>
                        <h4>Ejecución</h4>
                        <p>Realizamos la obra con supervisión constante.</p>
                    </div>

                    <div class="aboutPro__step">
                        <span>4</span>
                        <h4>Entrega final</h4>
                        <p>Resultado final listo para disfrutar.</p>
                    </div>

                </div>
            </div>
        </div>
        </section>
</Layout>